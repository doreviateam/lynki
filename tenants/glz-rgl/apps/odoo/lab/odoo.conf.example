[options]
; Copier ce fichier vers odoo.conf et définir admin_passwd (non versionné).
admin_passwd = __CHANGE_ME__
db_host = odoo_db_lab_glz-rgl
db_port = 5432
db_user = odoo
db_password = odoo
dbfilter = ^odoo_lab_glz_rgl$
list_db = False

; Langue et localisation
lang = fr_FR

; addons (Odoo 19 — aligné lab o19)
; custom-addons avant addons-o19 (modules Dorevia prioritaires)
addons_path = /usr/lib/python3/dist-packages/odoo/addons,/mnt/custom-addons,/mnt/addons-o19,/mnt/extra-addons
data_dir = /var/lib/odoo

proxy_mode = True

server_wide_modules = web,queue_job
workers = 2

[queue_job]
channels = root:2
