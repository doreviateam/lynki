<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        Templates QWeb personnalisés Dorevia pour les rapports de vente.
        Basés sur sale.report_saleorder_document mais avec layout optimisé (col-12 pour totaux).
    -->
    
    <!-- Template wrapper pour Devis / Quotation -->
    <template id="report_quotation_dorevia">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <!-- CSS inline pour forcer la largeur en PDF (wkhtmltopdf ne respecte pas @media print) -->
                    <style>
                        /* Force largeur 100% pour la page et tous les conteneurs */
                        .page { width: 100% !important; max-width: 100% !important; }
                        /* Force largeur 100% pour tous les conteneurs de totaux en PDF */
                        table.o_total_table { 
                            width: 100% !important; 
                            max-width: 100% !important; 
                            margin: 0 !important; 
                            padding: 0 !important;
                            table-layout: fixed !important;
                        }
                        table.o_total_table * { 
                            box-sizing: border-box !important; 
                        }
                        /* Override Bootstrap si présent - très agressif */
                        .col-6, .col-sm-7, .col-md-6, [class*="col-"] { 
                            width: 100% !important; 
                            max-width: 100% !important; 
                            margin: 0 !important; 
                            padding: 0 !important; 
                            flex: none !important;
                        }
                        /* Force largeur sur tous les divs parents des totaux */
                        div[name="so_total_summary"],
                        div#total,
                        div#total > div {
                            width: 100% !important;
                            max-width: 100% !important;
                            margin: 0 !important;
                            padding: 0 !important;
                        }
                        /* Override ms-auto qui peut limiter la largeur */
                        .ms-auto { margin-left: 0 !important; margin-right: 0 !important; }
                    </style>
                    <t t-call="dorevia_sale_reports.report_saleorder_document_dorevia" t-lang="doc.partner_id.lang"/>
                </t>
            </t>
        </t>
    </template>
    
