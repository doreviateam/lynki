<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue liste des contrats -->
    <record id="view_dorevia_contract_tree" model="ir.ui.view">
        <field name="name">dorevia.contract.tree</field>
        <field name="model">dorevia.contract</field>
        <field name="arch" type="xml">
            <list string="Contrats" decoration-muted="active == False">
                <field name="name"/>
                <field name="tenant_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="active"/>
                <field name="tax_rate"/>
                <field name="tax_exempt"/>
            </list>
        </field>
    </record>

    <!-- Vue formulaire des contrats -->
    <record id="view_dorevia_contract_form" model="ir.ui.view">
        <field name="name">dorevia.contract.form</field>
        <field name="model">dorevia.contract</field>
        <field name="arch" type="xml">
            <form string="Contrat">
                <header>
                    <field name="active" widget="boolean_toggle"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="tenant_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="tax_rate"/>
                            <field name="tax_exempt"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Règles tarifaires">
                            <field name="pricing_rule_ids" nolabel="1">
                                <list string="Règles tarifaires" editable="bottom">
                                    <field name="move_type"/>
                                    <field name="fixed_amount"/>
                                    <field name="price_unit"/>
                                    <field name="currency_id"/>
                                    <field name="tier_from"/>
                                    <field name="tier_to"/>
                                    <field name="discount_percent"/>
                                    <field name="sequence"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue recherche des contrats -->
    <record id="view_dorevia_contract_search" model="ir.ui.view">
        <field name="name">dorevia.contract.search</field>
        <field name="model">dorevia.contract</field>
        <field name="arch" type="xml">
            <search string="Rechercher un contrat">
                <field name="name"/>
                <field name="tenant_id"/>
                <filter string="Actifs" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactifs" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Tenant" name="group_tenant" context="{'group_by': 'tenant_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action pour ouvrir la liste des contrats -->
    <record id="action_dorevia_contract" model="ir.actions.act_window">
        <field name="name">Contrats</field>
        <field name="res_model">dorevia.contract</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer un contrat
            </p>
            <p>
                Les contrats définissent les règles tarifaires appliquées lors de la facturation des constats.
            </p>
        </field>
    </record>
</odoo>

