<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue liste des règles tarifaires -->
    <record id="view_dorevia_pricing_rule_tree" model="ir.ui.view">
        <field name="name">dorevia.pricing.rule.tree</field>
        <field name="model">dorevia.pricing.rule</field>
        <field name="arch" type="xml">
            <list string="Règles tarifaires" decoration-muted="active == False">
                <field name="contract_id"/>
                <field name="move_type"/>
                <field name="fixed_amount"/>
                <field name="price_unit"/>
                <field name="currency_id"/>
                <field name="tier_from"/>
                <field name="tier_to"/>
                <field name="discount_percent"/>
                <field name="sequence"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Vue formulaire des règles tarifaires -->
    <record id="view_dorevia_pricing_rule_form" model="ir.ui.view">
        <field name="name">dorevia.pricing.rule.form</field>
        <field name="model">dorevia.pricing.rule</field>
        <field name="arch" type="xml">
            <form string="Règle tarifaire">
                <header>
                    <field name="active" widget="boolean_toggle"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="contract_id"/>
                            <field name="move_type"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="price_unit"/>
                            <field name="currency_id"/>
                            <field name="discount_percent"/>
                        </group>
                    </group>
                    <group string="Montant fixe">
                        <field name="fixed_amount"/>
                    </group>
                    <group string="Paliers">
                        <field name="tier_from"/>
                        <field name="tier_to" placeholder="Illimité"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue recherche des règles tarifaires -->
    <record id="view_dorevia_pricing_rule_search" model="ir.ui.view">
        <field name="name">dorevia.pricing.rule.search</field>
        <field name="model">dorevia.pricing.rule</field>
        <field name="arch" type="xml">
            <search string="Rechercher une règle tarifaire">
                <field name="contract_id"/>
                <field name="move_type"/>
                <filter string="Actives" name="active" domain="[('active', '=', True)]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Contrat" name="group_contract" context="{'group_by': 'contract_id'}"/>
                    <filter string="Type de mouvement" name="group_move_type" context="{'group_by': 'move_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action pour ouvrir la liste des règles tarifaires -->
    <record id="action_dorevia_pricing_rule" model="ir.actions.act_window">
        <field name="name">Règles tarifaires</field>
        <field name="res_model">dorevia.pricing.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

