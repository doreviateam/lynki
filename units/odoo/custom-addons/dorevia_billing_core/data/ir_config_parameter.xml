<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Token d'authentification pour l'API -->
        <record id="config_core_api_token" model="ir.config_parameter">
            <field name="key">dorevia_billing.core_api_token</field>
            <field name="value"></field>
        </record>

        <!-- Vérification JWS activée -->
        <record id="config_jws_verification_enabled" model="ir.config_parameter">
            <field name="key">dorevia_billing.jws_verification_enabled</field>
            <field name="value">False</field>
        </record>

        <!-- URL du JWKS du Vault -->
        <record id="config_jwks_url" model="ir.config_parameter">
            <field name="key">dorevia_billing.jwks_url</field>
            <field name="value"></field>
        </record>

        <!-- Validation automatique des factures -->
        <record id="config_auto_post_invoice" model="ir.config_parameter">
            <field name="key">dorevia_billing.auto_post_invoice</field>
            <field name="value">False</field>
        </record>
    </data>
</odoo>

