<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dorevia_helloasso_payment_api_import_wizard_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.payment.api.import.wizard.form</field>
        <field name="model">dorevia.helloasso.payment.api.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import API paiements HelloAsso">
                <sheet>
                    <group string="Import API">
                        <field name="helloasso_account_id"/>
                        <field name="company_id"/>
                        <field name="form_type"/>
                        <field name="form_slug"/>
                        <field name="import_platform_only"/>
                        <field name="page_size"/>
                        <field name="max_pages"/>
                    </group>
                    <p class="text-muted">
                        Import MVP via l'API HelloAsso.
                        Si l'option <strong>Limiter au MVP plateforme</strong> est active,
                        seuls les paiements qualifiés comme paiements plateforme sont importés.
                    </p>
                    <footer>
                        <button
                            name="action_import_api"
                            type="object"
                            string="Importer via l'API"
                            class="btn-primary"
                        />
                        <button string="Fermer" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dorevia_helloasso_payment_api_import_wizard" model="ir.actions.act_window">
        <field name="name">Import API paiements HelloAsso</field>
        <field name="res_model">dorevia.helloasso.payment.api.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
