<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dorevia_helloasso_payment_csv_wizard_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.payment.csv.wizard.form</field>
        <field name="model">dorevia.helloasso.payment.csv.wizard</field>
        <field name="arch" type="xml">
            <form string="Import CSV paiements HelloAsso">
                <sheet>
                    <group string="Import CSV">
                        <field name="helloasso_account_id"/>
                        <field name="company_id"/>
                        <field name="import_platform_only"/>
                        <field name="upload_filename" invisible="1"/>
                        <field name="upload_file" filename="upload_filename"/>
                    </group>
                    <p class="text-muted">
                        Import MVP à partir d'un export CSV HelloAsso.
                        Si l'option <strong>Limiter au MVP plateforme</strong> est active,
                        seules les lignes qualifiées comme paiements plateforme sont importées.
                    </p>
                    <footer>
                        <button
                            name="action_import_csv"
                            type="object"
                            string="Importer le CSV"
                            class="btn-primary"
                        />
                        <button string="Fermer" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dorevia_helloasso_payment_csv_wizard" model="ir.actions.act_window">
        <field name="name">Import CSV paiements HelloAsso</field>
        <field name="res_model">dorevia.helloasso.payment.csv.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
