<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_partner_form_membership" model="ir.ui.view">
        <field name="name">res.partner.form.membership</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page name="dorevia_membership" string="Adhésion">
                    <group>
                        <group string="Adhérent">
                            <field name="member_type_id" />
                        </group>
                        <group string="Consentement">
                            <field name="consent_personal_data" />
                            <field name="consent_date" />
                            <field name="consent_note" placeholder="Référence document, version CGU, etc." />
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_helloasso" model="ir.ui.view">
        <field name="name">res.partner.form.helloasso</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page
                    string="HelloAsso"
                    name="dorevia_helloasso"
                    groups="base.group_system"
                >
                    <group string="Traçabilité synchronisation">
                        <field name="helloasso_external_id"/>
                        <field name="helloasso_order_id"/>
                        <field name="helloasso_last_sync_at"/>
                        <field name="helloasso_sync_status"/>
                        <field name="helloasso_sync_form_caption" readonly="1"/>
                        <field name="helloasso_source_form_title"/>
                        <field name="helloasso_source_form"/>
                        <field name="helloasso_form_type"/>
                        <field name="helloasso_payment_date"/>
                        <field name="helloasso_payment_mean"/>
                        <field name="helloasso_payment_amount"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
