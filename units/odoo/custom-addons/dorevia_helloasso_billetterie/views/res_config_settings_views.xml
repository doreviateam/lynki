<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_helloasso_billetterie" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.helloasso.billetterie</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="dorevia_helloasso_members.res_config_settings_view_form_helloasso"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='dorevia_helloasso_settings_block']" position="after">
                <block title="HelloAsso (billetterie)" name="dorevia_helloasso_billetterie_settings_block">
                    <setting
                        string="Campagne billetterie par défaut"
                        help="Type et identifiant HelloAsso utilisés par l’assistant et les actions globales. Laisser l’identifiant vide pour prendre la première campagne du type choisi."
                    >
                        <field name="helloasso_billetterie_form_type"/>
                        <field name="helloasso_billetterie_form_slug" placeholder="ex. ma-soiree (optionnel)"/>
                    </setting>
                    <setting string="Actions billetterie">
                        <button
                            name="action_helloasso_billetterie_preview"
                            type="object"
                            string="Prévisualiser les commandes"
                            class="btn-secondary"
                        />
                        <button
                            name="action_helloasso_billetterie_sync_orders"
                            type="object"
                            string="Importer les commandes (défauts)"
                            class="btn-secondary"
                        />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
