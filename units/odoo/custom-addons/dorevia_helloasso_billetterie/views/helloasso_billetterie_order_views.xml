<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dorevia_helloasso_billetterie_order_tree" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.order.tree</field>
        <field name="model">dorevia.helloasso.billetterie.order</field>
        <field name="arch" type="xml">
            <list string="Commandes billetterie HelloAsso">
                <field name="name"/>
                <field name="helloasso_order_id"/>
                <field name="form_type"/>
                <field name="form_slug"/>
                <field name="catalog_form_id" optional="hide"/>
                <field name="state_raw"/>
                <field name="amount_total"/>
                <field name="date_order"/>
                <field name="payer_partner_id"/>
                <field name="last_sync_at"/>
            </list>
        </field>
    </record>

    <record id="view_dorevia_helloasso_billetterie_order_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.order.form</field>
        <field name="model">dorevia.helloasso.billetterie.order</field>
        <field name="arch" type="xml">
            <form string="Commande billetterie HelloAsso">
                <sheet>
                    <group>
                        <group string="Commande">
                            <field name="name" readonly="1"/>
                            <field name="helloasso_order_id" readonly="1"/>
                            <field name="form_type" readonly="1"/>
                            <field name="form_slug" readonly="1"/>
                            <field name="state_raw" readonly="1"/>
                            <field name="amount_total" readonly="1"/>
                            <field name="date_order" readonly="1"/>
                        </group>
                        <group string="Synchro">
                            <field name="catalog_form_id" readonly="1"/>
                            <field name="payer_partner_id"/>
                            <field name="sync_status" readonly="1"/>
                            <field name="last_sync_at" readonly="1"/>
                            <field name="sync_message" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lignes / participants">
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="ticket_label"/>
                                    <field name="item_type"/>
                                    <field name="participant_email"/>
                                    <field name="participant_first_name"/>
                                    <field name="participant_last_name"/>
                                    <field name="helloasso_item_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dorevia_helloasso_billetterie_order" model="ir.actions.act_window">
        <field name="name">Commandes billetterie HelloAsso</field>
        <field name="res_model">dorevia.helloasso.billetterie.order</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune commande billetterie synchronisée.
            </p>
            <p>
                Les <strong>adhésions</strong> et la <strong>billetterie</strong> sont deux flux distincts : cette liste se remplit uniquement après une synchronisation des commandes du formulaire <strong>événement</strong> (souvent type Event).
            </p>
            <p>
                Ouvrez <strong>Billetterie → Formulaires HelloAsso</strong> puis <strong>Synchroniser les commandes</strong> sur la ligne cible, ou <strong>Billetterie → Synchronisation</strong> pour une prévisualisation globale. Vous pouvez aussi configurer le <strong>form slug</strong> dans <strong>Configuration → Paramètres généraux</strong> (bloc HelloAsso billetterie).
            </p>
        </field>
    </record>
    <!-- Menus applicatifs : voir helloasso_menu_lot1.xml -->
</odoo>
