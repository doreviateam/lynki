<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dorevia_helloasso_billetterie_order_kanban" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.order.kanban</field>
        <field name="model">dorevia.helloasso.billetterie.order</field>
        <field name="type">kanban</field>
        <field name="arch" type="xml">
            <kanban
                default_group_by="form_slug"
                quick_create="false"
                create="false"
                class="o_kanban_small_column"
                decoration-danger="sync_status == 'error'"
            >
                <field name="id"/>
                <field name="name"/>
                <field name="helloasso_order_id"/>
                <field name="form_slug"/>
                <field name="billetterie_type_caption"/>
                <field name="state_raw"/>
                <field name="amount_total"/>
                <field name="date_order"/>
                <field name="payer_partner_id"/>
                <field name="last_sync_at"/>
                <field name="sync_status"/>
                <templates>
                    <t t-name="card" class="flex-row">
                        <aside class="o_kanban_aside_full pe-2 d-flex align-items-center justify-content-center rounded-3 bg-light" style="min-width: 52px; min-height: 52px;">
                            <span class="fa fa-shopping-cart fa-lg text-primary" title="Commande"/>
                        </aside>
                        <main class="min-w-0 flex-grow-1">
                            <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                                <field name="name" class="fw-bold text-truncate"/>
                                <field
                                    name="sync_status"
                                    widget="badge"
                                    decoration-danger="sync_status == 'error'"
                                    decoration-success="sync_status == 'synced'"
                                />
                            </div>
                            <div t-if="record.payer_partner_id.raw_value" class="text-muted small text-truncate">
                                <span class="fa fa-user me-1" title="Payeur HelloAsso"/>
                                <field name="payer_partner_id"/>
                            </div>
                            <div class="d-flex flex-wrap align-items-center gap-2 mt-2 small">
                                <span t-if="record.amount_total.raw_value" class="badge rounded-pill text-bg-primary">
                                    <field name="amount_total"/> €
                                </span>
                                <span t-if="record.state_raw.raw_value" class="badge text-bg-light border">
                                    <field name="state_raw"/>
                                </span>
                                <span t-if="record.billetterie_type_caption.raw_value" class="text-muted">
                                    <field name="billetterie_type_caption"/>
                                </span>
                            </div>
                            <div class="d-flex flex-wrap gap-3 mt-2 small text-muted">
                                <span t-if="record.date_order.raw_value">
                                    <span class="fa fa-calendar me-1" title="Date commande"/>
                                    <field name="date_order" widget="datetime"/>
                                </span>
                                <span t-if="record.last_sync_at.raw_value">
                                    <span class="fa fa-refresh me-1" title="Dernière mise à jour"/>
                                    <field name="last_sync_at" widget="datetime"/>
                                </span>
                            </div>
                            <div t-if="record.helloasso_order_id.raw_value" class="text-muted small mt-1">
                                <span class="fa fa-hashtag me-1" title="Réf. HelloAsso"/>
                                <field name="helloasso_order_id"/>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_dorevia_helloasso_billetterie_order_tree" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.order.tree</field>
        <field name="model">dorevia.helloasso.billetterie.order</field>
        <field name="arch" type="xml">
            <list string="Commandes billetterie" create="false">
                <field name="name"/>
                <field name="helloasso_order_id"/>
                <field name="billetterie_type_caption"/>
                <field name="form_slug"/>
                <field name="form_type" optional="hide" readonly="1"/>
                <field name="catalog_form_id" optional="hide"/>
                <field name="state_raw"/>
                <field name="amount_total"/>
                <field name="date_order"/>
                <field name="payer_partner_id"/>
                <field name="last_sync_at"/>
            </list>
        </field>
    </record>

    <record id="view_dorevia_helloasso_billetterie_order_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.order.form</field>
        <field name="model">dorevia.helloasso.billetterie.order</field>
        <field name="arch" type="xml">
            <form string="Commande billetterie" create="false">
                <sheet>
                    <group>
                        <group string="Commande">
                            <field name="name" readonly="1"/>
                            <field name="helloasso_order_id" readonly="1"/>
                            <field name="billetterie_type_caption" readonly="1"/>
                            <field name="form_slug" readonly="1"/>
                            <field name="form_type" readonly="1" groups="base.group_system"/>
                            <field name="state_raw" readonly="1"/>
                            <field name="amount_total" readonly="1"/>
                            <field name="date_order" readonly="1"/>
                        </group>
                        <group string="Import">
                            <field name="catalog_form_id" readonly="1"/>
                            <field name="payer_partner_id"/>
                            <field name="sync_status" readonly="1"/>
                            <field name="last_sync_at" readonly="1"/>
                            <field name="sync_message" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lignes / participants">
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="ticket_label"/>
                                    <field name="item_type"/>
                                    <field name="helloasso_payment_ids" optional="show"/>
                                    <field name="payment_share_euros" optional="show"/>
                                    <field name="payment_state_raw" optional="hide"/>
                                    <field name="participant_email"/>
                                    <field name="participant_first_name"/>
                                    <field name="participant_last_name"/>
                                    <field name="helloasso_item_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
