<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action adhésions : liste métier dédiée (vue helloasso_partner_membership_views.xml) -->
    <record id="action_helloasso_partner_adherents" model="ir.actions.act_window">
        <field name="name">Adhésion</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('dorevia_helloasso_billetterie.view_res_partner_kanban_helloasso_memberships')}),
                (0, 0, {'view_mode': 'list', 'view_id': ref('dorevia_helloasso_billetterie.view_res_partner_tree_helloasso_memberships')}),
            ]"
        />
        <field name="domain" eval="[('helloasso_external_id', '!=', False), ('helloasso_form_type', '=', 'Membership')]"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune adhésion HelloAsso synchronisée pour l’instant.
            </p>
            <p>
                Pour <strong>tenir la liste à jour</strong> avec HelloAsso : <strong>Paramètres généraux</strong> (bloc HelloAsso adhérent) → <strong>Synchroniser les adhérents</strong>, ou le <strong>planificateur</strong> si vous l’avez activé.
            </p>
        </field>
    </record>

    <!-- Synthèse connecteur (admin) — plus en entrée principale de l’app -->
    <record id="view_dorevia_helloasso_landing_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.landing.form</field>
        <field name="model">dorevia.helloasso.landing</field>
        <field name="arch" type="xml">
            <form string="Synthèse connecteur HelloAsso" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h1>HelloAsso</h1>
                        <p class="text-muted">
                            Indicateurs techniques et raccourcis — la collecte publique reste sur HelloAsso.
                        </p>
                    </div>
                    <group string="Configuration (Paramètres)">
                        <field name="env_label"/>
                        <field name="org_slug"/>
                        <field name="api_ready"/>
                    </group>
                    <group string="Synthèse des flux synchronisés">
                        <field name="count_adherents"/>
                        <field name="count_billetterie_orders"/>
                        <field name="last_adherent_sync_at"/>
                        <field name="last_billetterie_sync_at"/>
                    </group>
                    <group string="Raccourcis">
                        <div colspan="2">
                            <button
                                name="%(action_helloasso_partner_adherents)d"
                                type="action"
                                string="Adhésion"
                                class="btn-primary"
                            />
                            <button
                                name="%(action_dorevia_helloasso_billetterie_form)d"
                                type="action"
                                string="Billetteries"
                                class="btn-secondary"
                            />
                            <button
                                name="%(action_dorevia_helloasso_billetterie_order)d"
                                type="action"
                                string="Commandes"
                                class="btn-secondary"
                            />
                        </div>
                    </group>
                    <group string="Information">
                        <field name="help_text" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dorevia_helloasso_landing" model="ir.actions.act_window">
        <field name="name">Synthèse connecteur</field>
        <field name="res_model">dorevia.helloasso.landing</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- M6 : page d’aide applicative (pas de fiche technique / NewId visible) -->
    <record id="view_dorevia_helloasso_form_guide_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.form.guide.form</field>
        <field name="model">dorevia.helloasso.form.guide</field>
        <field name="arch" type="xml">
            <form string="Aide HelloAsso" edit="false" create="false" delete="false" duplicate="false">
                <sheet>
                    <div class="oe_title">
                        <h1>Aide HelloAsso</h1>
                        <p class="text-muted">
                            Réponses courtes pour vous orienter. Les ventes et campagnes publiques restent sur HelloAsso.
                        </p>
                    </div>
                    <group string="Rappel (votre site)">
                        <field name="env_label"/>
                        <field name="org_slug"/>
                        <field name="count_event_forms"/>
                    </group>
                    <group string="Questions fréquentes">
                        <div colspan="2">
                            <p class="mb-3">
                                <strong>Où voir les adhésions ?</strong><br/>
                                Menu <strong>HelloAsso</strong> → <strong>Adhésion</strong>.
                            </p>
                            <p class="mb-3">
                                <strong>Où voir les billetteries ?</strong><br/>
                                <strong>HelloAsso</strong> → <strong>Billetterie</strong> → <strong>Billetteries</strong>.
                            </p>
                            <p class="mb-3">
                                <strong>Où voir les commandes importées ?</strong><br/>
                                <strong>HelloAsso</strong> → <strong>Billetterie</strong> → <strong>Commandes</strong>.
                            </p>
                            <p class="mb-0">
                                <strong>Où se règle la connexion HelloAsso ?</strong><br/>
                                <strong>Paramètres généraux</strong> (icône engrenage) → section <strong>HelloAsso</strong> : organisation, essai ou production, identifiants API. Cette configuration sert à la fois à l’adhésion et à la billetterie.
                            </p>
                        </div>
                    </group>
                    <group string="Raccourcis">
                        <div colspan="2" class="d-flex flex-wrap gap-2">
                            <button
                                name="%(action_helloasso_partner_adherents)d"
                                type="action"
                                string="Adhésion"
                                class="btn-secondary"
                            />
                            <button
                                name="%(action_dorevia_helloasso_billetterie_form)d"
                                type="action"
                                string="Billetteries"
                                class="btn-secondary"
                            />
                            <button
                                name="%(action_dorevia_helloasso_billetterie_order)d"
                                type="action"
                                string="Commandes"
                                class="btn-secondary"
                            />
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dorevia_helloasso_form_guide" model="ir.actions.act_window">
        <field name="name">Aide HelloAsso</field>
        <field name="res_model">dorevia.helloasso.form.guide</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- Entrées métier d’abord ; Configuration en dernier ; synthèse sous Configuration (admin) -->
    <menuitem
        id="menu_dorevia_helloasso_root"
        name="HelloAsso"
        web_icon="dorevia_helloasso_billetterie,static/description/icon.png"
        sequence="35"
    />
    <menuitem
        id="menu_helloasso_adherents"
        name="Adhésion"
        parent="menu_dorevia_helloasso_root"
        action="action_helloasso_partner_adherents"
        sequence="5"
    />
    <!-- Rubrique Billetterie : inventaire des campagnes + commandes (sous-domaine fonctionnel) -->
    <menuitem
        id="menu_helloasso_billetterie"
        name="Billetterie"
        parent="menu_dorevia_helloasso_root"
        sequence="15"
    />
    <menuitem
        id="menu_helloasso_billetterie_forms"
        name="Billetteries"
        parent="menu_helloasso_billetterie"
        action="action_dorevia_helloasso_billetterie_form"
        sequence="5"
    />
    <menuitem
        id="menu_helloasso_billetterie_orders"
        name="Commandes"
        parent="menu_helloasso_billetterie"
        action="action_dorevia_helloasso_billetterie_order"
        sequence="15"
    />
    <menuitem
        id="menu_helloasso_form_guide"
        name="Aide"
        parent="menu_dorevia_helloasso_root"
        action="action_dorevia_helloasso_form_guide"
        sequence="40"
    />
</odoo>
