<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action adhésions : liste métier dédiée (vue helloasso_partner_membership_views.xml) -->
    <record id="action_helloasso_partner_adherents" model="ir.actions.act_window">
        <field name="name">Adhésion</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form,kanban</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0), (0, 0, {'view_mode': 'list', 'view_id': ref('dorevia_helloasso_billetterie.view_res_partner_tree_helloasso_memberships')})]"
        />
        <field name="domain" eval="[('helloasso_external_id', '!=', False), ('helloasso_form_type', '=', 'Membership')]"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune adhésion HelloAsso synchronisée pour l’instant.
            </p>
            <p>
                Pour <strong>tenir la liste à jour</strong> avec HelloAsso : <strong>Paramètres généraux</strong> (bloc HelloAsso adhérent) → <strong>Synchroniser les adhérents</strong>, ou le <strong>planificateur</strong> si vous l’avez activé.
            </p>
        </field>
    </record>

    <!-- Synthèse connecteur (admin) — plus en entrée principale de l’app -->
    <record id="view_dorevia_helloasso_landing_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.landing.form</field>
        <field name="model">dorevia.helloasso.landing</field>
        <field name="arch" type="xml">
            <form string="Synthèse connecteur HelloAsso" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h1>HelloAsso</h1>
                        <p class="text-muted">
                            Indicateurs techniques et raccourcis — la collecte publique reste sur HelloAsso.
                        </p>
                    </div>
                    <group string="Configuration (Paramètres)">
                        <field name="env_label"/>
                        <field name="org_slug"/>
                        <field name="api_ready"/>
                    </group>
                    <group string="Synthèse des flux synchronisés">
                        <field name="count_adherents"/>
                        <field name="count_billetterie_orders"/>
                        <field name="last_adherent_sync_at"/>
                        <field name="last_billetterie_sync_at"/>
                    </group>
                    <group string="Raccourcis">
                        <div colspan="2">
                            <button
                                name="%(action_helloasso_partner_adherents)d"
                                type="action"
                                string="Adhésion"
                                class="btn-primary"
                            />
                            <button
                                name="%(action_dorevia_helloasso_billetterie_form)d"
                                type="action"
                                string="Billetteries"
                                class="btn-secondary"
                            />
                            <button
                                name="%(action_dorevia_helloasso_billetterie_order)d"
                                type="action"
                                string="Commandes"
                                class="btn-secondary"
                            />
                        </div>
                    </group>
                    <group string="Information">
                        <field name="help_text" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dorevia_helloasso_landing" model="ir.actions.act_window">
        <field name="name">Synthèse connecteur</field>
        <field name="res_model">dorevia.helloasso.landing</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- Entrées métier d’abord ; Configuration en dernier ; synthèse sous Configuration (admin) -->
    <menuitem
        id="menu_dorevia_helloasso_root"
        name="HelloAsso"
        web_icon="dorevia_helloasso_billetterie,static/description/icon.png"
        sequence="35"
    />
    <menuitem
        id="menu_helloasso_adherents"
        name="Adhésion"
        parent="menu_dorevia_helloasso_root"
        action="action_helloasso_partner_adherents"
        sequence="5"
    />
    <!-- Billetteries : liste des formulaires Event (comme Adhésion = liste adhérents) ; commandes via en-tête -->
    <menuitem
        id="menu_helloasso_billetterie"
        name="Billetteries"
        parent="menu_dorevia_helloasso_root"
        action="action_dorevia_helloasso_billetterie_form"
        sequence="15"
    />
</odoo>
