<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dorevia_helloasso_billetterie_sync_wizard_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.sync.wizard.form</field>
        <field name="model">dorevia.helloasso.billetterie.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Synchronisation billetterie HelloAsso">
                <sheet>
                    <group string="Cible actuelle (paramètres serveur)">
                        <field name="helloasso_sandbox"/>
                        <field name="helloasso_org_slug"/>
                        <field name="helloasso_form_type"/>
                        <field name="helloasso_form_slug"/>
                    </group>
                    <p class="text-muted">
                        Consultez d’abord le menu <strong>Billetteries</strong> (ou le bouton du même nom en tête de liste Commandes) pour identifier le
                        <strong>form slug</strong> et le <strong>type</strong> de chaque formulaire.
                        Une <strong>campagne</strong> HelloAsso peut être adhésion, don, billetterie, etc. : ici ne concernent que les
                        <strong>billetteries</strong> (billets), en pratique un formulaire <strong>événement</strong> — pas le slug d’une adhésion.
                        Pour modifier les paramètres par défaut : application <strong>Paramètres</strong> → <strong>Paramètres généraux</strong> → bloc HelloAsso (billetterie).
                    </p>
                    <footer>
                        <button
                            name="action_helloasso_billetterie_preview"
                            type="object"
                            string="Prévisualiser les commandes"
                            class="btn-secondary"
                        />
                        <button
                            name="action_helloasso_billetterie_sync_orders"
                            type="object"
                            string="Synchroniser la billetterie"
                            class="btn-primary"
                        />
                        <button string="Fermer" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dorevia_helloasso_billetterie_sync_wizard" model="ir.actions.act_window">
        <field name="name">Synchronisation billetterie</field>
        <field name="res_model">dorevia.helloasso.billetterie.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
</odoo>
