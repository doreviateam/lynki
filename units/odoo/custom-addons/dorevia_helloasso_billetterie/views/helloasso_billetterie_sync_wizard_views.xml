<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dorevia_helloasso_billetterie_sync_wizard_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.sync.wizard.form</field>
        <field name="model">dorevia.helloasso.billetterie.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Assistant — billetterie HelloAsso">
                <sheet>
                    <group string="Réglages actuels (paramètres)">
                        <field name="helloasso_sandbox"/>
                        <field name="helloasso_org_slug"/>
                        <field name="helloasso_form_type"/>
                        <field name="helloasso_form_slug"/>
                    </group>
                    <p class="text-muted">
                        Ouvrez d’abord le menu <strong>Billetteries</strong> (<strong>HelloAsso → Billetterie → Billetteries</strong>) pour repérer le
                        <strong>type</strong> et l’<strong>identifiant HelloAsso</strong> de chaque campagne.
                        Seules les <strong>billetteries</strong> (billets / événements) sont concernées ici, pas les adhésions.
                        Pour modifier les valeurs par défaut : <strong>Paramètres</strong> → <strong>Paramètres généraux</strong> → bloc HelloAsso billetterie.
                    </p>
                    <footer>
                        <button
                            name="action_helloasso_billetterie_preview"
                            type="object"
                            string="Prévisualiser les commandes"
                            class="btn-secondary"
                        />
                        <button
                            name="action_helloasso_billetterie_sync_orders"
                            type="object"
                            string="Importer les commandes"
                            class="btn-primary"
                        />
                        <button string="Fermer" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dorevia_helloasso_billetterie_sync_wizard" model="ir.actions.act_window">
        <field name="name">Assistant billetterie</field>
        <field name="res_model">dorevia.helloasso.billetterie.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
</odoo>
