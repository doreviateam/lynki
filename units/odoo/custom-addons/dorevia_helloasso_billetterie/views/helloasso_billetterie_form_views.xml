<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dorevia_helloasso_billetterie_form_tree" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.form.list</field>
        <field name="model">dorevia.helloasso.billetterie.form</field>
        <field name="arch" type="xml">
            <list string="Billetteries" create="false">
                <header>
                    <button
                        name="action_sync_orders"
                        type="object"
                        string="Importer les commandes"
                        title="Import HelloAsso pour les billetteries cochées. Cochez une ou plusieurs lignes pour activer cette action."
                        class="btn-secondary"
                        display="selection"
                    />
                </header>
                <field name="name"/>
                <field name="use_sandbox" optional="show" readonly="1"/>
                <field name="billetterie_org_caption"/>
                <field name="billetterie_type_caption"/>
                <field name="form_slug"/>
                <field name="organization_slug" optional="hide" readonly="1"/>
                <field name="form_type" optional="hide" readonly="1"/>
                <field name="last_inventory_at" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_dorevia_helloasso_billetterie_form_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.form.form</field>
        <field name="model">dorevia.helloasso.billetterie.form</field>
        <field name="arch" type="xml">
            <form string="Billetterie" create="false">
                <header>
                    <button
                        name="action_sync_orders"
                        type="object"
                        string="Importer les commandes"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_open_orders"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-shopping-cart"
                        >
                            <field name="order_count" widget="statinfo" string="Commandes"/>
                        </button>
                    </div>
                    <group>
                        <group string="Référence HelloAsso">
                            <field name="name" readonly="1"/>
                            <field name="helloasso_title" readonly="1"/>
                            <field name="use_sandbox" readonly="1"/>
                            <field name="billetterie_org_caption" readonly="1"/>
                            <field name="billetterie_type_caption" readonly="1"/>
                            <field name="form_slug" readonly="1"/>
                            <field name="organization_slug" readonly="1" groups="base.group_system"/>
                            <field name="form_type" readonly="1" groups="base.group_system"/>
                        </group>
                        <group string="Suivi">
                            <field name="last_inventory_at" readonly="1"/>
                            <field name="comment" placeholder="Priorité, remarques métier, lien avec une billetterie / un événement…"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dorevia_helloasso_billetterie_form_search" model="ir.ui.view">
        <field name="name">dorevia.helloasso.billetterie.form.search</field>
        <field name="model">dorevia.helloasso.billetterie.form</field>
        <field name="arch" type="xml">
            <search string="Billetteries">
                <field name="name"/>
                <field name="billetterie_org_caption"/>
                <field name="billetterie_type_caption"/>
                <field name="form_slug"/>
                <filter string="Essai HelloAsso" name="sandbox" domain="[('use_sandbox', '=', True)]"/>
                <filter string="Production HelloAsso" name="production" domain="[('use_sandbox', '=', False)]"/>
                <filter string="Billetteries" name="filter_event" domain="[('form_type', '=ilike', 'event')]"/>
                <filter string="Autres campagnes" name="filter_non_event" domain="['!', ('form_type', 'ilike', 'event')]"/>
                <separator/>
                <filter string="Par type" name="group_form_type" context="{'group_by': 'billetterie_type_caption'}"/>
                <filter string="Par organisation" name="group_org" context="{'group_by': 'organization_slug'}"/>
            </search>
        </field>
    </record>

    <!-- Liste : menu Action — rechargement référentiel (API globale, occasionnel) -->
    <record id="action_server_billetterie_form_refresh_inventory" model="ir.actions.server">
        <field name="name">Recharger le référentiel billetteries (HelloAsso)</field>
        <field name="model_id" ref="model_dorevia_helloasso_billetterie_form"/>
        <field name="binding_model_id" ref="model_dorevia_helloasso_billetterie_form"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = env["dorevia.helloasso.billetterie.form"].browse([]).action_refresh_inventory_from_helloasso()</field>
    </record>

    <!-- Liste : menu Action — import (même logique que le bouton d’en-tête contextualisé) -->
    <record id="action_server_billetterie_form_sync_orders" model="ir.actions.server">
        <field name="name">Importer les commandes HelloAsso</field>
        <field name="model_id" ref="model_dorevia_helloasso_billetterie_form"/>
        <field name="binding_model_id" ref="model_dorevia_helloasso_billetterie_form"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_sync_orders()</field>
    </record>

    <record id="action_server_billetterie_form_open_orders" model="ir.actions.server">
        <field name="name">Ouvrir la liste des commandes</field>
        <field name="model_id" ref="model_dorevia_helloasso_billetterie_form"/>
        <field name="binding_model_id" ref="model_dorevia_helloasso_billetterie_form"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = env.ref("dorevia_helloasso_billetterie.action_dorevia_helloasso_billetterie_order").sudo().read()[0]</field>
    </record>

    <record id="action_server_billetterie_form_open_sync_wizard" model="ir.actions.server">
        <field name="name">Assistant de synchronisation (paramètres)</field>
        <field name="model_id" ref="model_dorevia_helloasso_billetterie_form"/>
        <field name="binding_model_id" ref="model_dorevia_helloasso_billetterie_form"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = env.ref("dorevia_helloasso_billetterie.action_dorevia_helloasso_billetterie_sync_wizard").sudo().read()[0]</field>
    </record>
</odoo>
