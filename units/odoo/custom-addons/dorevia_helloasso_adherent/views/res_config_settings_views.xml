<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_helloasso" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.helloasso</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='companies']" position="after">
                <block title="HelloAsso (adhérents)" name="dorevia_helloasso_settings_block">
                    <setting
                        string="Identifiants API"
                        help="Client ID et secret depuis HelloAsso : Mon compte → Intégrations et API. Préférer le sandbox pour les tests (REF_API)."
                    >
                        <field name="helloasso_use_sandbox"/>
                        <field name="helloasso_organization_slug" placeholder="ex. mon-association"/>
                        <field name="helloasso_client_id"/>
                        <field name="helloasso_client_secret" password="True"/>
                    </setting>
                    <setting string="Actions (MVP)">
                        <button
                            name="action_helloasso_test_connection"
                            type="object"
                            string="Tester la connexion"
                            class="btn-primary"
                        />
                        <button
                            name="action_helloasso_preview_data"
                            type="object"
                            string="Prévisualiser les données HelloAsso"
                            class="btn-secondary"
                        />
                        <button
                            name="action_helloasso_sync_members"
                            type="object"
                            string="Synchroniser les adhérents"
                            class="btn-secondary"
                        />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
