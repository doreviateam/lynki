<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dorevia_helloasso_sync_log_tree" model="ir.ui.view">
        <field name="name">dorevia.helloasso.logentry.list</field>
        <field name="model">dorevia.helloasso.logentry</field>
        <field name="arch" type="xml">
            <list string="Journal HelloAsso" create="false">
                <field name="create_date" string="Date"/>
                <field name="create_uid" string="Par"/>
                <field name="flow"/>
                <field name="origin"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'success'"
                    decoration-warning="state == 'warning'"
                    decoration-danger="state == 'error'"
                />
                <field name="summary"/>
            </list>
        </field>
    </record>

    <record id="view_dorevia_helloasso_sync_log_form" model="ir.ui.view">
        <field name="name">dorevia.helloasso.logentry.form</field>
        <field name="model">dorevia.helloasso.logentry</field>
        <field name="arch" type="xml">
            <form string="Exécution synchro HelloAsso" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" string="Date"/>
                            <field name="create_uid" string="Utilisateur"/>
                            <field name="flow"/>
                            <field name="origin"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="summary" colspan="2"/>
                        </group>
                    </group>
                    <group string="Détail">
                        <field name="detail" nolabel="1" colspan="2" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dorevia_helloasso_sync_log" model="ir.actions.act_window">
        <field name="name">Journal des synchronisations</field>
        <field name="res_model">dorevia.helloasso.logentry</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune synchronisation enregistrée pour l’instant.
            </p>
            <p>
                Les exécutions lancées depuis les <strong>Paramètres</strong>, l’<strong>assistant billetterie</strong>,
                le <strong>planificateur</strong> ou l’<strong>inventaire formulaires</strong> apparaissent ici avec un résumé et le détail JSON des compteurs.
            </p>
        </field>
    </record>
</odoo>
