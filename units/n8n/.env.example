# Unit n8n — Dorevia Plateforme
# Copier vers .env et adapter. Ne pas commiter .env

# Contexte déploiement (aligné manifest)
DEPLOY_ENV=lab
TENANT_ID=lab

# Domaine public (hostname Caddy)
N8N_DOMAIN=n8n.lab.lab.doreviateam.com

# Obligatoire : clé de chiffrement n8n (stable, ne jamais perdre)
N8N_ENCRYPTION_KEY=change-me-32-chars-minimum-secret

# PostgreSQL (interne au compose)
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=change-me

# Images (optionnel)
# N8N_IMAGE=n8nio/n8n:latest
# N8N_DB_IMAGE=postgres:16

# Fuseau
TZ=Europe/Paris
