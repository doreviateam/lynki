# Unit SuiteCRM — Dorevia Plateforme
# Copier vers .env et adapter. Ne pas commiter .env

# Contexte déploiement (aligné manifest)
DEPLOY_ENV=lab
TENANT_ID=lab

# Domaine public (hostname Caddy)
SUITECRM_DOMAIN=suitecrm.lab.lab.doreviateam.com

# Base MariaDB
SUITECRM_DB_NAME=suitecrm
SUITECRM_DB_USER=suitecrm
SUITECRM_DB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me-root

# Admin SuiteCRM
SUITECRM_ADMIN_USER=admin
SUITECRM_ADMIN_PASSWORD=change-me-admin

# Images (optionnel ; défauts dans compose)
# SUITECRM_IMAGE=bitnami/suitecrm:8
# SUITECRM_DB_IMAGE=mariadb:11

# Fuseau
TZ=Europe/Paris
