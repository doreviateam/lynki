# DIVA — Store persistant + Runner
# Copier en .env et adapter (les valeurs ci-dessous sont pour lab/stinger)

# Store Postgres (base Vault). Si vide → fallback mémoire.
DIVA_DATABASE_URL=postgres://vault:vault_password@vault-db-core-stinger:5432/dorevia_vault

# Runner CODIR
RUNNER_ENABLED=true
RUNNER_TENANT_CONFIG=sarl-la-platine:1
LINKY_URL=http://linky_lab_sarl-la-platine:3000
DIVA_URL=http://diva:8010
