# Dorevia Lynki — variables d'environnement de référence
# Copier ce fichier en .env.local (dev) ou .env.production (prod)
# et remplir les valeurs.

# ─── Vault ───────────────────────────────────────────────────────────────────
# URL du Vault interne (sans slash final)
VAULT_URL=http://vault:8080

# Tenant par défaut si non fourni en query param
TENANT_ID=core

# ─── Doctrine comptable (C5 — Gate B Sprint 05) ───────────────────────────
# LINKY_ACCOUNTING_STRICT=1 :
#   Si Vault injoignable ou erreur HTTP → 502 explicite sur toutes les routes
#   /api/accounting/* (trial-balance, general-ledger, exports).
#   Aucun fallback stub silencieux en environnement de référence.
#
# Laisser à 0 (ou absent) uniquement en développement local sans Vault démarré.
LINKY_ACCOUNTING_STRICT=1

# ─── Rôles / habilitations (Sprint 06 T32) ───────────────────────────────────
# Tokens opaques associés à chaque rôle.
# Admin      : accès complet (Synthèse, GL, admin, export)
# Controller : accès Synthèse + GL + export ; pas de pages /admin
# Manager    : accès lecture Synthèse ; pas d'export, pas de GL dédié
LINKY_ADMIN_TOKEN=changeme-admin
LINKY_CONTROLLER_TOKEN=changeme-controller
LINKY_MANAGER_TOKEN=changeme-manager

# ─── DIVA (insights) ─────────────────────────────────────────────────────────
# DIVA_URL=http://diva:9090

# ─── DLP (énergie) ───────────────────────────────────────────────────────────
# DLP_URL=http://dlp:8090
