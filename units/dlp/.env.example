# DLP — Decision Link Performance
# SPEC : ZeDocs/web31/SPEC_DLP_v0.3.md

# Port du service (défaut 8020)
DLP_PORT=8020

# Base PostgreSQL dédiée DLP (requis)
# En local : postgres://dlp:dlp_password@localhost:5433/dorevia_dlp
# Avec docker-compose : postgres://dlp:dlp_password@dlp-db:5432/dorevia_dlp
DATABASE_URL=postgres://dlp:dlp_password@dlp-db:5432/dorevia_dlp

# Niveau de log (info, debug)
DLP_LOG_LEVEL=info

# Optionnel : chemin migrations (défaut ./migrations)
# DLP_MIGRATIONS_DIR=./migrations
