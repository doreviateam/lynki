# Unit Appsmith CE — Dorevia Plateforme
# Copier vers .env et adapter. Ne pas commiter .env
# SPEC : ZeDocs/web13/unit_appSmith.md

# Contexte déploiement (aligné manifest)
DEPLOY_ENV=lab
TENANT_ID=core

# Domaine public (hostname Caddy) — convention ui.<env>.<tenant>.<domaine>
APPSMITH_DOMAIN=ui.lab.core.doreviateam.com

# Obligatoire : chiffrement Appsmith (stable, ne jamais perdre)
# Générer des valeurs fortes (ex: openssl rand -base64 32)
APPSMITH_ENCRYPTION_PASSWORD=change-me-strong-password-32-chars-min
APPSMITH_ENCRYPTION_SALT=change-me-strong-salt-32-chars-min

# Nom affiché dans l'interface (optionnel)
APPSMITH_INSTANCE_NAME=Dorevia-UI

# Image (optionnel)
# APPSMITH_IMAGE=appsmith/appsmith-ce:release

# Fuseau
TZ=Europe/Paris
