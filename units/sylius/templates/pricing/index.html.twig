{% block javascripts %}
<script>
    // Calculateur pricing
    const calculatorButton = document.getElementById('calculator-button');
    const calculatorPlan = document.getElementById('calculator-plan');
    const calculatorInvoices = document.getElementById('calculator-invoices');
    const calculatorResult = document.getElementById('calculator-result');
    const calculatorDetails = document.getElementById('calculator-details');
    const calculatorRecommendation = document.getElementById('calculator-recommendation');

    function calculatePrice() {
        const plan = calculatorPlan.value;
        const invoices = parseInt(calculatorInvoices.value) || 0;

        if (invoices < 0) {
            alert('Le nombre de factures doit être positif');
            return;
        }

        calculatorButton.disabled = true;
        calculatorButton.textContent = 'Calcul en cours...';

        fetch('{{ path("api_pricing_calculate") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ plan, invoices }),
        })
        .then(response => response.json())
        .then(data => {
            if (data.status === 'success') {
                const calc = data.calculation;
                
                // Tracking analytics
                if (typeof trackEvent === 'function') {
                    trackEvent('Pricing', 'calculate', plan, calc.total);
                }
                const planNames = {
                    'starter': 'STARTER',
                    'business': 'BUSINESS',
                    'scale': 'SCALE'
                };

                calculatorDetails.innerHTML = `
                    <div style="padding: 1rem; background: #f1f5f9; border-radius: 8px;">
                        <p style="font-size: 0.75rem; color: #64748b; margin-bottom: 0.25rem; text-transform: uppercase; font-weight: 600;">Abonnement</p>
                        <p style="font-size: 1.1rem; color: #1e293b; margin: 0; font-weight: 700;">${calc.base_price.toFixed(2)} €</p>
                        <p style="font-size: 0.8rem; color: #64748b; margin-top: 0.25rem;">${calc.included_invoices} factures incluses</p>
                    </div>
                    ${calc.overage_invoices > 0 ? `
                    <div style="padding: 1rem; background: #fef3c7; border-radius: 8px;">
                        <p style="font-size: 0.75rem; color: #64748b; margin-bottom: 0.25rem; text-transform: uppercase; font-weight: 600;">Supplément</p>
                        <p style="font-size: 1.1rem; color: #1e293b; margin: 0; font-weight: 700;">${calc.overage_total.toFixed(2)} €</p>
                        <p style="font-size: 0.8rem; color: #64748b; margin-top: 0.25rem;">${calc.overage_invoices} × ${calc.overage_price.toFixed(2)} €</p>
                    </div>
                    ` : ''}
                    <div style="padding: 1rem; background: linear-gradient(135deg, #10b981 0%, #059669 100%); border-radius: 8px; color: white;">
                        <p style="font-size: 0.75rem; color: rgba(255, 255, 255, 0.9); margin-bottom: 0.25rem; text-transform: uppercase; font-weight: 600;">Total</p>
                        <p style="font-size: 1.5rem; color: white; margin: 0; font-weight: 800;">${calc.total.toFixed(2)} €</p>
                        <p style="font-size: 0.8rem; color: rgba(255, 255, 255, 0.9); margin-top: 0.25rem;">par mois</p>
                    </div>
                `;

                if (data.recommendation) {
                    const recNames = {
                        'business': 'BUSINESS',
                        'scale': 'SCALE'
                    };
                    calculatorRecommendation.innerHTML = `
                        <p style="color: #92400e; margin: 0; font-weight: 600;">
                            💡 <strong>Recommandation :</strong> Avec ${invoices} factures/mois, le plan <strong>${recNames[data.recommendation]}</strong> pourrait être plus économique.
                        </p>
                    `;
                    calculatorRecommendation.style.display = 'block';
                } else {
                    calculatorRecommendation.style.display = 'none';
                }

                calculatorResult.style.display = 'block';
                calculatorResult.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } else {
                alert('Erreur : ' + data.message);
            }
        })
        .catch(error => {
            console.error('Erreur:', error);
            alert('Une erreur est survenue lors du calcul');
        })
        .finally(() => {
            calculatorButton.disabled = false;
            calculatorButton.textContent = 'Calculer mon prix';
        });
    }

    if (calculatorButton) {
        calculatorButton.addEventListener('click', calculatePrice);
    }

    // Auto-calcul lors du changement
    if (calculatorPlan && calculatorInvoices) {
        calculatorPlan.addEventListener('change', () => {
            if (calculatorResult.style.display === 'block') {
                calculatePrice();
            }
        });
        calculatorInvoices.addEventListener('input', () => {
            if (calculatorResult.style.display === 'block') {
                calculatePrice();
            }
        });
    }

    // FAQ Accordéon
    function toggleFaq(button) {
        const item = button.closest('.faq-item');
        const answer = item.querySelector('.faq-answer');
        const icon = button.querySelector('.faq-icon');
        const isOpen = answer.style.display === 'block';

        // Fermer toutes les autres FAQ
        document.querySelectorAll('.faq-answer').forEach(a => {
            if (a !== answer) {
                a.style.display = 'none';
                a.closest('.faq-item').querySelector('.faq-icon').textContent = '+';
                a.closest('.faq-item').querySelector('.faq-icon').style.transform = 'rotate(0deg)';
            }
        });

        // Toggle la FAQ actuelle
        if (isOpen) {
            answer.style.display = 'none';
            icon.textContent = '+';
            icon.style.transform = 'rotate(0deg)';
        } else {
            answer.style.display = 'block';
            icon.textContent = '−';
            icon.style.transform = 'rotate(180deg)';
        }
    }
</script>
{% endblock %}
