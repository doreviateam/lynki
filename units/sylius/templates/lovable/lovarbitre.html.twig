    <script>
        // Mobile menu
        const menuBtn = document.getElementById('menuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        menuBtn?.addEventListener('click', () => {
            const isOpen = mobileMenu.classList.toggle('open');
            menuBtn.setAttribute('aria-expanded', String(isOpen));
        });
        mobileMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            menuBtn.setAttribute('aria-expanded', 'false');
        }));

        // Demo mock
        const dispute = document.getElementById('dispute');
        const whistleBtn = document.getElementById('whistleBtn');
        const fillExampleBtn = document.getElementById('fillExampleBtn');
        const result = document.getElementById('result');

        const examples = [
            "Tu m'as interrompu trois fois. Et après tu dis que je parle trop…",
            "Tu dis que tu as compris, puis tu refais pareil. J'ai l'impression de parler à un mur.",
            "Je te demande un truc simple, et ça finit en débat sur 2019. (La VAR chauffe.)"
        ];

        fillExampleBtn?.addEventListener('click', () => {
            dispute.value = examples[Math.floor(Math.random() * examples.length)];
            dispute.focus();
        });

        function clamp(n, a, b) {
            return Math.max(a, Math.min(b, n));
        }

        function renderMock(text) {
            const t = (text || "").toLowerCase();

            // Heuristiques simples pour donner un rendu "outil réel"
            let interruptions = (t.match(/interromp|coupe|coupé|couper/g) || []).length;
            let alwaysNever = (t.match(/toujours|jamais/g) || []).length;
            let past = (t.match(/2019|avant|l'autre fois|la dernière fois/g) || []).length;
            let attaque = (t.match(/nul|stupid|idiot|ridicule|honte/g) || []).length;

            let fautesA = 1 + interruptions + alwaysNever + past;
            let fautesB = 1 + Math.floor((alwaysNever + past) / 2);

            // Indice drama
            let drama = 3.5 + interruptions * 0.8 + alwaysNever * 0.9 + attaque * 1.2 + past * 0.7;
            drama = Math.round(clamp(drama, 0, 10) * 10) / 10;

            // Possession (pseudo)
            let possessionA = clamp(52 + interruptions * 3 + alwaysNever * 2 - past * 1, 35, 72);
            let possessionB = 100 - possessionA;

            // Cartons
            let jauneA = clamp(Math.floor((fautesA) / 3), 0, 3);
            let rougeA = (attaque > 0 || fautesA >= 7) ? 1 : 0;
            let jauneB = clamp(Math.floor((fautesB) / 3), 0, 2);
            let rougeB = (fautesB >= 7) ? 1 : 0;

            // Verdict
            const scoreA = (possessionA / 10) - (fautesA * 0.6) - (rougeA * 3) - (jauneA * 0.8);
            const scoreB = (possessionB / 10) - (fautesB * 0.6) - (rougeB * 3) - (jauneB * 0.8);
            const winner = scoreA >= scoreB ? "Joueur B" : "Joueur A"; // fun: celui qui commet le moins de fautes "gagne"
            const note = past > 0
                ? "VAR : rétro‑match détecté. Retour au sujet conseillé."
                : (interruptions > 0 ? "Possession contestée : moins couper, plus marquer des points." : "Belle première mi‑temps : continuez à parler simple.");

            function cartons(jaune, rouge) {
                return "🟨".repeat(jaune) + (jaune === 0 ? "—" : "") + "  " + "🟥".repeat(rouge) + (rouge === 0 ? "—" : "");
            }

            result.innerHTML = `
                <div class="pill"><span class="dot"></span> Arbitrage rendu (mock)</div>

                <div class="mini-card" style="border-color: rgba(250,227,88,.22);">
                    <b>Verdict</b>
                    <span><b>Victoire aux points :</b> ${winner}</span><br/>
                    <span style="opacity:.88;">(oui, c'est volontairement un peu taquin)</span>
                </div>

                <div class="cards-mini">
                    <div class="mini-card">
                        <b>Cartons</b>
                        <span><b>Joueur A :</b> ${cartons(jauneA, rougeA)}<br/>
                              <b>Joueur B :</b> ${cartons(jauneB, rougeB)}</span>
                    </div>
                    <div class="mini-card">
                        <b>Stats</b>
                        <span><b>Possession :</b> A ${possessionA}% / B ${possessionB}%<br/>
                              <b>Fautes :</b> A ${fautesA} / B ${fautesB}<br/>
                              <b>Drama :</b> ${drama}/10</span>
                    </div>
                </div>

                <div class="mini-card" style="border-color: rgba(201,57,37,.28);">
                    <b>Note de l'arbitre</b>
                    <span>"${note}"</span>
                </div>

                <div style="display:flex; flex-wrap:wrap; gap:10px;">
                    <a class="btn btn-primary" href="#demo">🟥 Rejouer</a>
                    <a class="btn btn-secondary inverse" href="#stats">📊 Voir le tableau</a>
                </div>
            `;
        }

        whistleBtn?.addEventListener('click', () => {
            const text = dispute.value.trim();
            if (!text) {
                dispute.focus();
                dispute.setAttribute('aria-invalid', 'true');
                renderMock("interrompu toujours 2019"); // small nudge
                return;
            }
            dispute.removeAttribute('aria-invalid');
            renderMock(text);
        });
    </script>
</body>
</html>
