{% extends 'layout.html.twig' %}

{% block title %}{{ page_title }}{% endblock %}
{% block meta_description %}{{ page_description }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('assets/css/landing-v2-final.css') }}?v={{ 'now'|date('U') }}" />
    <link rel="stylesheet" href="{{ asset('assets/css/blog-v2.css') }}?v={{ 'now'|date('U') }}" />
    <link rel="stylesheet" href="{{ asset('assets/css/blog-v3.css') }}?v={{ 'now'|date('U') }}" />
    <style>
        body { background: var(--blog-bg) !important; }
        .ud-header, .ud-footer { display: none !important; }
    </style>
    {# Structured Data JSON-LD pour SEO #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Blog Dorevia-Vault",
      "description": "{{ page_description|e('js') }}",
      "url": "{{ app.request.uri }}",
      "publisher": {
        "@type": "Organization",
        "name": "Dorevia-Vault",
        "logo": {
          "@type": "ImageObject",
          "url": "https://sylius.lab.core.doreviateam.com/assets/images/logo/logo.svg"
        }
      }
    }
    </script>
{% endblock %}

{% block body %}
<div class="blog-v2">
    <!-- POSITIONNEMENT ÉDITORIAL (en haut, avant tout) -->
    <section class="blog-intro-section">
        <div class="blog-v2-container">
            <div class="blog-section-title">
                <h1 class="blog-section-heading">Journal d'infrastructure de preuve financière</h1>
                <p class="blog-section-description">
                    Analyses, conformité, ERP et bonnes pratiques pour piloter votre entreprise avec des chiffres prouvables.
                    <br><em style="font-size: 0.95em; color: var(--muted);">Explications claires. Zéro marketing. Zéro jargon inutile.</em>
                </p>
            </div>
        </div>
    </section>

    <!-- HERO SECTION (Featured Article) - Après le positionnement -->
    {% if featured_article and current_page == 1 and not current_search %}
    <section class="blog-hero">
        <div class="blog-v2-container">
            <a href="{{ path('blog_show', {slug: featured_article.slug}) }}" style="text-decoration: none; color: inherit;">
                <div class="blog-hero-card">
                    <div class="blog-hero-content">
                        <span class="blog-hero-badge">⭐ Article à la une</span>
                        <h2 class="blog-hero-title">{{ featured_article.title }}</h2>
                        {% if featured_article.excerpt %}
                            <p class="blog-hero-excerpt">{{ featured_article.excerpt }}</p>
                        {% endif %}
                        <div class="blog-hero-meta">
                            <div class="blog-hero-meta-item">
                                <span>📅</span>
                                <span>{{ featured_article.publishedAt|date('d/m/Y') }}</span>
                            </div>
                            <div class="blog-hero-meta-item">
                                <span>✍️</span>
                                <span>{{ featured_article.author }}</span>
                            </div>
                            <div class="blog-hero-meta-item">
                                <span>⏱️</span>
                                <span>{{ featured_article.readingTime }} min de lecture</span>
                            </div>
                        </div>
                        <div class="blog-card-link">
                            Lire l'article <span>→</span>
                        </div>
                    </div>
                    <div class="blog-hero-image-wrapper">
                        {% set coverImage = featured_article.coverImage ?: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1200&h=600&fit=crop&q=80' %}
                        <img src="{{ coverImage }}" alt="{{ featured_article.title }}" class="blog-hero-image" loading="lazy">
                    </div>
                </div>
            </a>
        </div>
    </section>
    {% endif %}

    <!-- MAIN CONTENT -->
    <section style="padding: 0 0 80px;">
        <div class="blog-v2-container">
            <!-- Recherche plein texte (après le hero, bien visible) -->
            <div class="blog-search-wrapper">
                <form method="GET" action="{{ path('blog_index') }}" class="blog-search-form">
                    <input 
                        type="text" 
                        name="search" 
                        value="{{ current_search }}" 
                        placeholder="Rechercher dans le journal" 
                        class="blog-search-input"
                        autocomplete="off"
                    >
                    <span class="blog-search-hint">(preuve, NF525, facture, audit, Odoo, conformité…)</span>
                    {% if current_category %}
                        <input type="hidden" name="category" value="{{ current_category }}">
                    {% endif %}
                    <button type="submit" class="blog-search-button" aria-label="Rechercher">🔍</button>
                </form>
                {% if current_search %}
                    <div class="blog-search-results-info">
                        <span>{{ total_articles }} résultat{% if total_articles > 1 %}s{% endif %} pour "{{ current_search }}"</span>
                        <a href="{{ path('blog_index') }}" class="blog-search-clear">✕ Effacer</a>
                    </div>
                {% endif %}
            </div>

            <!-- Filtres thématiques (selon spec) -->
            {% set theme_categories = [
                'Conformité & réglementation',
                'ERP & Odoo CE',
                'Trésorerie & pilotage',
                'Preuve & audit',
                'Architecture & sécurité'
            ] %}
            <div class="blog-filters-wrapper">
                <div class="blog-filters">
                    <a href="{{ path('blog_index') }}" 
                       class="blog-filter-link {% if not current_category %}blog-filter-active{% endif %}">
                        Tous
                        {% if total_published is defined %}
                            <span class="blog-filter-count">({{ total_published }})</span>
                        {% endif %}
                    </a>
                    {% for cat in theme_categories %}
                        {% set count = category_counts[cat] ?? 0 %}
                        <a href="{{ path('blog_index', {category: cat}) }}" 
                           class="blog-filter-link {% if current_category == cat %}blog-filter-active{% endif %}">
                            {{ cat }}
                            <span class="blog-filter-count">({{ count }})</span>
                        </a>
                    {% endfor %}
                </div>
            </div>

            <!-- Articles Grid -->
            {% if articles|length > 0 %}
                <div class="blog-grid">
                    {% for article in articles %}
                        <a href="{{ path('blog_show', {slug: article.slug}) }}" class="blog-card">
                            <div class="blog-card-image-wrapper">
                                {% set coverImage = article.coverImage ?: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1200&h=600&fit=crop&q=80' %}
                                <img src="{{ coverImage }}" alt="{{ article.title }}" class="blog-card-image" loading="lazy">
                            </div>
                            <div class="blog-card-content">
                                {% if article.category %}
                                    {% set categoryColors = {
                                        'Conformité & réglementation': 'background: #BFCDEB; color: #1A2B4C;',
                                        'ERP & Odoo CE': 'background: #A7E2D8; color: #1A2B4C;',
                                        'Trésorerie & pilotage': 'background: #FDEAA8; color: #1A2B4C;',
                                        'Preuve & audit': 'background: #FDD2D5; color: #1A2B4C;',
                                        'Architecture & sécurité': 'background: #BFCDEB; color: #1A2B4C;'
                                    } %}
                                    {% set categoryStyle = categoryColors[article.category] ?? 'background: var(--blog-accent-soft); color: var(--blog-accent);' %}
                                    <div style="display: inline-block; padding: 4px 12px; {{ categoryStyle }} border-radius: 6px; font-size: 11px; font-weight: 600; margin-bottom: 12px;">
                                        {{ article.category }}
                                    </div>
                                {% endif %}
                                <div class="blog-card-meta">
                                    <span>📅 {{ article.publishedAt|date('d/m/Y') }}</span>
                                    <span>⏱️ {{ article.readingTime }} min</span>
                                </div>
                                <h3 class="blog-card-title">{{ article.title }}</h3>
                                {% if article.excerpt %}
                                    <p class="blog-card-excerpt">{{ article.excerpt|slice(0, 140) }}{% if article.excerpt|length > 140 %}...{% endif %}</p>
                                {% endif %}
                                <span class="blog-card-link">Lire →</span>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="blog-empty">
                    <p class="blog-empty-text">Aucun article publié pour le moment.</p>
                </div>
            {% endif %}

            <!-- CTA permanent discret -->
            <div class="blog-cta-soft">
                <p class="blog-cta-text">
                    👉 <strong>Préparez votre conformité 2026</strong> — <a href="{{ path('home') }}#contact-section" class="blog-cta-link">Diagnostic gratuit</a>
                </p>
            </div>

            <!-- Pagination -->
            {% if total_pages > 1 %}
                <nav class="blog-pagination">
                    {% if current_page > 1 %}
                        {% if current_search %}
                            <a href="{{ path('blog_index', {page: current_page - 1, search: current_search}) }}" class="blog-pagination-link">← Précédent</a>
                        {% elseif current_category %}
                            <a href="{{ path('blog_index', {page: current_page - 1, category: current_category}) }}" class="blog-pagination-link">← Précédent</a>
                        {% else %}
                            <a href="{{ path('blog_index', {page: current_page - 1}) }}" class="blog-pagination-link">← Précédent</a>
                        {% endif %}
                    {% endif %}
                    
                    {% for page in 1..total_pages %}
                        {% if page == current_page %}
                            <span class="blog-pagination-link blog-pagination-current">{{ page }}</span>
                        {% elseif page == 1 or page == total_pages or (page >= current_page - 2 and page <= current_page + 2) %}
                            {% if current_search %}
                                <a href="{{ path('blog_index', {page: page, search: current_search}) }}" class="blog-pagination-link">{{ page }}</a>
                            {% elseif current_category %}
                                <a href="{{ path('blog_index', {page: page, category: current_category}) }}" class="blog-pagination-link">{{ page }}</a>
                            {% else %}
                                <a href="{{ path('blog_index', {page: page}) }}" class="blog-pagination-link">{{ page }}</a>
                            {% endif %}
                        {% elseif page == current_page - 3 or page == current_page + 3 %}
                            <span class="blog-pagination-ellipsis">...</span>
                        {% endif %}
                    {% endfor %}

                    {% if current_page < total_pages %}
                        {% if current_search %}
                            <a href="{{ path('blog_index', {page: current_page + 1, search: current_search}) }}" class="blog-pagination-link">Suivant →</a>
                        {% elseif current_category %}
                            <a href="{{ path('blog_index', {page: current_page + 1, category: current_category}) }}" class="blog-pagination-link">Suivant →</a>
                        {% else %}
                            <a href="{{ path('blog_index', {page: current_page + 1}) }}" class="blog-pagination-link">Suivant →</a>
                        {% endif %}
                    {% endif %}
                </nav>
            {% endif %}

        </div>
    </section>

    <!-- FOOTER BLOG (Indépendant selon SPEC) -->
    {% include 'components/footer-blog.html.twig' %}
</div>
{% endblock %}
