    <!-- ====== Démarrer (Contact / Formulaire) ====== -->
    <section class="ud-contact" id="contact-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="ud-section-title mx-auto text-center">
                        <span>Démarrer</span>
                        <h2>Prêt pour des chiffres incontestables ?</h2>
                        <p>Diagnostic de votre contexte technique et réglementaire (15 min). Réponse sous 24h, sans engagement.</p>
                    </div>
                </div>
            </div>
            <div class="row justify-content-center" style="margin-top: 3rem;">
                <div class="col-lg-8 col-xl-6">
                    <div class="play-pills">
                        <div class="play-pill"><span class="play-dot"></span> Réponse garantie sous 24h</div>
                        <div class="play-pill"><span class="play-dot brand"></span> Sans engagement</div>
                    </div>
                    <div id="form-message" style="display: none; margin-bottom: 20px;"></div>
                    {{ form_start(form, {'attr': {'id': 'lead-form', 'action': path('lead_submit'), 'class': 'ud-contact-form'}}) }}
                        <div class="ud-form-group" style="margin-bottom: 1.5rem;">
                            <label for="{{ form.email.vars.id }}">Email professionnel</label>
                            {{ form_widget(form.email, {'attr': {'class': 'ud-form-control form-control', 'placeholder': 'nom@entreprise.fr'}}) }}
                        </div>
                        <div class="ud-form-group" style="margin-bottom: 1.5rem;">
                            <label for="{{ form.message.vars.id }}">Contexte technique (ERP...)</label>
                            {{ form_widget(form.message, {'attr': {'class': 'ud-form-control form-control', 'placeholder': 'Quel ERP utilisez-vous ? Quel est votre volume de facturation ?', 'rows': 4}}) }}
                        </div>
                        <div style="display:none;">{{ form_rest(form) }}</div>
                        <button type="submit" class="ud-main-btn" id="submit-button" style="width: 100%; padding: 16px; font-size: 16px;">Demander une démo</button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/bootstrap.bundle.min.js') }}"></script>
    <script src="{{ asset('assets/js/wow.min.js') }}"></script>
    <script>
        (function() {
            if (typeof WOW !== 'undefined') new WOW().init();
            var leadForm = document.getElementById('lead-form');
            if (!leadForm) return;
            leadForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                var submitBtn = document.getElementById('submit-button');
                var messageDiv = document.getElementById('form-message');
                var formData = new FormData(this);
                submitBtn.disabled = true;
                submitBtn.textContent = 'Envoi...';
                try {
                    var response = await fetch(this.action, { method: 'POST', body: formData });
                    var data = await response.json();
                    if (data.status === 'success') {
                        messageDiv.innerHTML = '<div class="play-alert-success"><strong>Succès.</strong> Nous vous recontactons sous 24h.</div>';
                        messageDiv.style.display = 'block';
                        leadForm.reset();
                    } else {
                        messageDiv.innerHTML = '<div class="play-alert-danger">' + (data.message || 'Erreur.') + '</div>';
                        messageDiv.style.display = 'block';
                    }
                } catch (err) {
                    messageDiv.innerHTML = '<div class="play-alert-danger">Erreur réseau.</div>';
                    messageDiv.style.display = 'block';
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Demander une démo';
                }
            });
            document.querySelectorAll('a.ud-menu-scroll[href^="#"]').forEach(function(a) {
                a.addEventListener('click', function(e) {
                    var href = this.getAttribute('href');
                    if (href && href.length > 1) {
                        var el = document.querySelector(href);
                        if (el) { e.preventDefault(); el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
                    }
                });
            });
        })();
    </script>
{% endblock %}
