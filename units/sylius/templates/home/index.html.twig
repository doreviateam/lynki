{% extends 'layout_play.html.twig' %}

{% block title %}Dorevia-Vault — Chiffres prouvables pour piloter la trésorerie.{% endblock %}
{% block meta_description %}Dorevia-Vault sécurise vos événements financiers à la source. Des preuves fiables, vérifiables et juridiquement opposables.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
    <!-- ====== Hero (Play Bootstrap — contenu Dorevia) ====== -->
