            </div>
        </div>
    </section>

    <!-- ====== Trust bar ====== -->
    <section class="ud-trust-bar" aria-hidden="true">
        <div class="container">
            <p style="margin: 0;">Conçu pour NF525 & e-invoicing 2026 • Hébergement France • Compatible Odoo & Multi-ERP</p>
        </div>
    </section>

    <!-- ====== Pourquoi Dorevia-Vault (Le problème) ====== -->
