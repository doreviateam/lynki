{# Encadré Exemple - Scénario concret ERP / CFO / audit #}
<div class="blog-encadre blog-encadre-exemple" style="background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%); border-left: 4px solid #0ea5e9; border-radius: var(--blog-radius); padding: 24px; margin: 2rem 0;">
    <div style="display: flex; align-items: start; gap: 12px;">
        <div style="font-size: 24px; line-height: 1;">🔍</div>
        <div style="flex: 1;">
            <div style="font-size: 12px; font-weight: 700; color: #0c4a6e; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                Exemple
            </div>
            <div class="blog-encadre-content" style="color: #0c4a6e; font-size: 16px; line-height: 1.7;">
                {{ content|raw }}
            </div>
        </div>
    </div>
</div>
