{# Header V2 - Composant réutilisable pour toutes les pages #}
<header class="v2-header" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px); border-bottom: 1px solid var(--line);">
    <div class="v2-container">
        <nav style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0;">
            <a href="{{ path('home') }}" class="v2-logo">
                <div class="v2-logo-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <div class="v2-logo-text">Dorevia<span>-Vault</span></div>
            </a>
            
            <div class="v2-navlinks" style="display: flex; gap: 32px; align-items: center;">
                <a href="{{ path('blog_index') }}" {% if app.request.attributes.get('_route') starts with 'blog' %}style="color: var(--accent); font-weight: 600;"{% endif %}>Blog</a>
                <a href="{{ path('ressources') }}" {% if app.request.attributes.get('_route') == 'ressources' %}style="color: var(--accent); font-weight: 600;"{% endif %}>Ressources</a>
                <a href="{{ path('home') }}#contact-section" class="btn btn-primary btn-press" style="padding: 10px 20px; font-size: 13px; border-radius: 8px; white-space: nowrap;">Diagnostic expert</a>
            </div>
            
            {# Menu hamburger pour mobile #}
            <button class="v2-menu-toggle" aria-label="Menu" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </nav>
        
        {# Menu mobile #}
        <div class="v2-mobile-menu">
            <div class="v2-mobile-menu-content">
                <a href="{{ path('blog_index') }}" {% if app.request.attributes.get('_route') starts with 'blog' %}class="active"{% endif %}>Blog</a>
                <a href="{{ path('ressources') }}" {% if app.request.attributes.get('_route') == 'ressources' %}class="active"{% endif %}>Ressources</a>
                <a href="{{ path('home') }}#contact-section" class="btn btn-primary">Diagnostic expert</a>
            </div>
        </div>
    </div>
</header>
