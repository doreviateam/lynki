{# CTA doux - Obligatoire en fin d'article selon SPEC v1.0 #}
<div class="blog-cta-doux" style="background: var(--blog-surface); border: 1px solid var(--blog-line); border-radius: var(--blog-radius); padding: 40px; margin: 4rem 0; text-align: center;">
    <h3 style="font-size: 22px; font-weight: 700; color: var(--blog-text); margin-bottom: 16px;">
        Aller plus loin
    </h3>
    <p style="font-size: 16px; color: var(--blog-muted); margin-bottom: 32px; max-width: 500px; margin-left: auto; margin-right: auto;">
        Vérifiez la compatibilité avec votre ERP ou découvrez une preuve réelle.
    </p>
    <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="{{ path('home') }}#contact-section" class="btn btn-primary" style="padding: 14px 28px; font-size: 15px; border-radius: 10px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
            Vérifier la compatibilité avec votre ERP
        </a>
        <a href="{{ path('home') }}#fonctionnement" class="btn btn-secondary" style="padding: 14px 28px; font-size: 15px; border-radius: 10px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
            Voir une preuve réelle
        </a>
    </div>
</div>
