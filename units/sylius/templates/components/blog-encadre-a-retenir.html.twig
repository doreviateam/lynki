{# Encadré À retenir - 3 points max, 1 par article #}
<div class="blog-encadre blog-encadre-a-retenir" style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border-left: 4px solid #f59e0b; border-radius: var(--blog-radius); padding: 24px; margin: 2rem 0;">
    <div style="display: flex; align-items: start; gap: 12px;">
        <div style="font-size: 24px; line-height: 1;">💡</div>
        <div style="flex: 1;">
            <div style="font-size: 12px; font-weight: 700; color: #92400e; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px;">
                À retenir
            </div>
            <ul style="margin: 0; padding-left: 20px; color: #78350f; font-size: 16px; line-height: 1.8;">
                {% for point in points %}
                    <li style="margin-bottom: 8px;">{{ point|raw }}</li>
                {% endfor %}
            </ul>
        </div>
    </div>
</div>
