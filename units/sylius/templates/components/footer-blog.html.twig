{# Footer Blog - Indépendant, sans pricing/CTA commercial selon SPEC v1.0 #}
<footer style="padding: 80px 0 40px; border-top: 1px solid var(--line); background: #fff;">
    <div class="v2-container">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-bottom: 40px; padding-bottom: 40px; border-bottom: 1px solid var(--line);">
            <!-- Colonne gauche : Signature éditoriale -->
            <div>
                <a href="{{ path('home') }}" class="v2-logo" style="font-size: 20px; margin-bottom: 20px; display: inline-block;">
                    <div class="v2-logo-icon" style="width: 28px; height: 28px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                    <div class="v2-logo-text">Dorevia<span>-Vault</span></div>
                </a>
                <p style="color: var(--muted); font-size: 14px; line-height: 1.6; margin: 0 0 16px 0; max-width: 400px;">
                    <strong style="color: var(--text);">Journal d'infrastructure de preuve financière.</strong>
                </p>
                <p style="color: var(--muted2); font-size: 13px; line-height: 1.6; margin: 0; max-width: 400px;">
                    Ce blog explique, clarifie, structure — il ne vend pas. Vocabulaire précis, accessible. Orientation risque, mécanisme, conformité.
                </p>
            </div>
            
            <!-- Colonne droite : Liens légaux -->
            <div style="display: flex; flex-direction: column; gap: 16px;">
                <div style="font-size: 12px; font-weight: 700; color: var(--muted2); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">
                    Informations
                </div>
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    <a href="{{ path('privacy_index') }}" style="color: var(--muted); text-decoration: none; font-size: 14px; transition: color 0.2s ease;">
                        Confidentialité
                    </a>
                    <a href="#" style="color: var(--muted); text-decoration: none; font-size: 14px; transition: color 0.2s ease;">
                        Mentions légales
                    </a>
                    <a href="{{ path('home') }}" style="color: var(--muted); text-decoration: none; font-size: 14px; transition: color 0.2s ease;">
                        Accueil
                    </a>
                </div>
            </div>
        </div>
        
        <!-- Ligne du bas : Copyright -->
        <div style="display: flex; justify-content: space-between; align-items: center; color: var(--muted2); font-size: 13px;">
            <span>© {{ "now"|date("Y") }} Dorevia Team. Tous droits réservés.</span>
            <span style="display: flex; align-items: center; gap: 8px;">
                <span>🇫🇷</span>
                <span>🇬🇵</span>
            </span>
        </div>
    </div>
</footer>
