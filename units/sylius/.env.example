# Configuration Landing Page Dorevia-Vault (Sylius)
# Version: 1.2
# Environnement: LAB

# ============================================
# Application Symfony
# ============================================
APP_ENV=prod
APP_DEBUG=0
DEPLOY_ENV=lab

# ============================================
# Base de données PostgreSQL
# ============================================
POSTGRES_USER=sylius
POSTGRES_PASSWORD=sylius_password
POSTGRES_DB=sylius_db

# URL de connexion Doctrine (générée automatiquement depuis variables ci-dessus)
# Format: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://sylius:sylius_password@postgres:5432/sylius_db

# ============================================
# Intégration Odoo CRM
# ============================================
ODOO_URL=https://odoo.lab.core.doreviateam.com
ODOO_DB=odoo_db
ODOO_API_USER=sylius_api_user
ODOO_API_PASSWORD=secure_password
ODOO_TEAM_ID=1
ODOO_USER_ID=1

# ============================================
# Notes
# ============================================
# 1. Copier ce fichier vers .env et adapter les valeurs
# 2. Ne jamais commiter le fichier .env dans Git
# 3. Les mots de passe doivent être sécurisés en production
